# ==============================================================
#  WebBuilder — Example environment configuration
#  Copy this file to .env and fill in your values.
#  Never commit your real .env to version control.
# ==============================================================


# --------------------------------------------------------------
# Django
# --------------------------------------------------------------

# Generate a strong secret key, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-django-secret-key-here


# --------------------------------------------------------------
# PostgreSQL
# --------------------------------------------------------------

DB_NAME=webbuilder_db
DB_USER=webbuilder_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432


# --------------------------------------------------------------
# LLM — any provider that implements the OpenAI /chat/completions format
# Uncomment the block for the provider you want to use.
# --------------------------------------------------------------

# · OpenRouter  ·················································
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=qwen/qwen3-coder:free

# · Groq  ························································
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct


# --------------------------------------------------------------
# n8n webhooks
# Update the base URL if n8n is not running on localhost:5678.
# --------------------------------------------------------------

# Deploy workflow — receives the generated ZIP and launches a Docker container
N8N_DEPLOY_WEBHOOK=http://localhost:5678/webhook/webbuilder-deploy

# Absolute path on the n8n host where the ZIP files are written before deploy
N8N_LOCAL_FILES_PATH=/path/to/n8n/local-files

# Auth notification workflows
N8N_WEBHOOK_REGISTRO=http://localhost:5678/webhook/WebBuilder-Register
N8N_WEBHOOK_LOGIN=http://localhost:5678/webhook/WebBuilder-Login

# Generation-done notification workflow
N8N_WEBHOOK_GENERATION_DONE=http://localhost:5678/webhook/webbuilder-generation-done


# --------------------------------------------------------------
# Internal API
# --------------------------------------------------------------

# Static token used to authenticate internal endpoints (health-check, metrics…)
INTERNAL_TOKEN=your-internal-token-here


# --------------------------------------------------------------
# Field encryption
# Used to encrypt/decrypt user-provided LLM API keys in the database.
# Generate a new key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# --------------------------------------------------------------

FIELD_ENCRYPTION_KEY=your-fernet-encryption-key-here